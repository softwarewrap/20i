                                    }
                                },
                                zone:{
                                    options: ["string"]
                                },
                                provider:{
                                    options: ["string"]
                                },
                                country:{
                                    options: ["string"]
                                }
                            },
                            cta: "string",
                            uiLabel: "string",
                            specName: "string",
                            basketLabel: "string"
                        }
                    },
                }
            


