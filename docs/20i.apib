                    "user" => [
                        {
                            "Username" => "string",
                            "Domain" => "string",
                            "Password" => "string",
                            "JailFrom" => "string"
                        }
                    ]
                ]
            ],
            "update" => [
                "ftp" => [
                    {
                        "id" => "string",
                        "user" => [
                            "Password" => "string",
                            "JailFrom" => "string",
                            "UnlockedUntil" => "string",
                            "Enabled" => true
                        ],
                        "acl" => "string"
                    }
                ]
            ],
            "delete" => [
                "ftp" => [
                    "id" => ["string"]
                ]
            ]
    ]);
```
+ Parameters

    + packageId: 1 (number, required) - The Package ID retrieved from get packages.


+ Attributes

    + `new` (object,required) - 
        - `ftp` (object,required) - 
            - `user` (array[object],required) - 
             +  use "/" for root
    + `update` (object,required) - 
        - `ftp` (array[object],required) - 
    + `delete` (object,required) - 
        - `ftp` (object,required) - 
            - `id` (array[string],required) - 
     
+ Request (application/json)

    + Headers

            Authorization: Bearer token

    + Body

            {
                    new:{
                        ftp:{
                            user:{
                                Username: "string",
                                Domain: "string",
                                Password: "string",
                                JailFrom: "string"
                            }
                        }
                    },
                    update:{
                        ftp:{
                            id: "string",
                            user:{
                                Password: "string",
                                JailFrom: "string",
                                UnlockedUntil: "string",
                                Enabled: true
                            },
                            acl: "string"
                        }
                    },
                    delete:{
                        ftp:{
                            id: ["string"]
                        }
                    }
            }

